config {
    type: "table",
    schema: "marts",
    tags: ["15 minutes"],
    description: "calculates projected stockout dates and reorder requirements based on multi-scenario forecasts (bau vs sales goal).",
    assertions: {
      uniqueKey: ["product_sku"]
    }
}

with 
-- recent_sales_velocity: calculates historical baseline performance
-- grain: one row per product_sku
-- purpose: provides 30/90 day trailing averages across channels for context and validation.
recent_sales_velocity as (
    select
        product_sku,
        -- total sales velocity
        safe_divide(sum(case when transaction_date >= date_sub(current_date(), interval 30 day) then units else 0 end), 30) as total_sales_30_day_avg,
        safe_divide(sum(case when transaction_date >= date_sub(current_date(), interval 90 day) then units else 0 end), 90) as total_sales_90_day_avg,
        
        -- amazon-specific velocity
        safe_divide(sum(case when merchant = 'amazon' and transaction_date >= date_sub(current_date(), interval 30 day) then units else 0 end), 30) as amazon_sales_30_day_avg,
        safe_divide(sum(case when merchant = 'amazon' and transaction_date >= date_sub(current_date(), interval 90 day) then units else 0 end), 90) as amazon_sales_90_day_avg,
        
        -- shopify-specific velocity
        safe_divide(sum(case when merchant = 'shopify' and transaction_date >= date_sub(current_date(), interval 30 day) then units else 0 end), 30) as shopify_sales_30_day_avg,
        safe_divide(sum(case when merchant = 'shopify' and transaction_date >= date_sub(current_date(), interval 90 day) then units else 0 end), 90) as shopify_sales_90_day_avg
    from 
        ${ref("fact_sales_transactions")}
    where 
        transaction_date >= date_sub(current_date(), interval 90 day)
    group by 1
),

-- burn_rate_simulation: identifies predicted stockout dates
-- grain: one row per product_sku
-- purpose: simulates inventory depletion by joining current on-hand stock against daily seasonal forecasts.
burn_rate_simulation as (
    select 
        prd.product_sku,
        prd.target_sales_goal,
        prd.avg_shipping_amount_per_unit,
        cti.inventory_in_transit_to_ffe,
        cti.inventory_ffe, 
        cti.inventory_in_transit_to_amz, 
        cti.inventory_amz_inventory,
        cti.total_inventory,
        -- scenario 1: business as usual (bau)
        min(case when f5.daily_units_running_sum >= cti.total_inventory then f5.projected_transaction_date end) as stockout_date_bau,
        -- scenario 2: aggressive sales goal applied
        min(case when (f5.daily_units_running_sum * prd.target_sales_goal) >= cti.total_inventory then f5.projected_transaction_date end) as stockout_date_goal
    from
        ${ref('dim_product')} prd 
        left join ${ref('t_current_inventory')} cti on cti.product_sku = prd.product_sku 
        left join ${ref('t_forecast_5_years_sales_forecast')} f5 on f5.product_sku = prd.product_sku 
    group by all
),

-- future_demand_projection: quantifies reorder units based on predicted gaps
-- grain: one row per product_sku
-- purpose: look-forward windowing to calculate required purchase units for 6-month and 12-month coverage.
future_demand_projection as (
    select
        --product metadata
        brs.product_sku,
        brs.target_sales_goal,
        brs.avg_shipping_amount_per_unit,
        --inventory
        brs.inventory_in_transit_to_ffe,
        brs.inventory_ffe, 
        brs.inventory_in_transit_to_amz, 
        brs.inventory_amz_inventory,
        brs.total_inventory,
        --dates
        brs.stockout_date_bau,
        brs.stockout_date_goal,
        -- bau reorder requirements
        sum(case 
            when f5.projected_transaction_date > brs.stockout_date_bau 
                 and f5.projected_transaction_date <= date_add(brs.stockout_date_bau, interval 6 month)
            then f5.daily_units else 0 end) as units_needed_6mo_bau,
        sum(case 
            when f5.projected_transaction_date > brs.stockout_date_bau 
                 and f5.projected_transaction_date <= date_add(brs.stockout_date_bau, interval 12 month)
            then f5.daily_units else 0 end) as units_needed_12mo_bau,
        
        -- sales goal reorder requirements
        sum(case 
            when f5.projected_transaction_date > brs.stockout_date_goal 
                 and f5.projected_transaction_date <= date_add(brs.stockout_date_goal, interval 6 month)
            then (f5.daily_units * brs.target_sales_goal) else 0 end) as units_needed_6mo_goal,
        sum(case 
            when f5.projected_transaction_date > brs.stockout_date_goal 
                 and f5.projected_transaction_date <= date_add(brs.stockout_date_goal, interval 12 month)
            then (f5.daily_units * brs.target_sales_goal) else 0 end) as units_needed_12mo_goal
    from
        burn_rate_simulation brs 
        left join ${ref('t_forecast_5_years_sales_forecast')} f5 on f5.product_sku = brs.product_sku
    group by all
)

-- final select: merges metadata and financial cost calculations
select 
    prd.product_sku,
    prd.product_name,
    prd.days_to_ship_over_sea,
    prd.unit_price,
    -- projections and inventory metrics
    fdp.* except(product_sku, target_sales_goal, avg_shipping_amount_per_unit),
    -- cost logic: bau
    fdp.units_needed_6mo_bau * prd.unit_price as cost_6mo_units_bau,
    fdp.units_needed_6mo_bau * fdp.avg_shipping_amount_per_unit as cost_6mo_shipping_bau,
    fdp.units_needed_12mo_bau * prd.unit_price as cost_12mo_units_bau,
    fdp.units_needed_12mo_bau * fdp.avg_shipping_amount_per_unit as cost_12mo_shipping_bau,
    -- cost logic: goal
    fdp.units_needed_6mo_goal * prd.unit_price as cost_6mo_units_goal,
    fdp.units_needed_6mo_goal * fdp.avg_shipping_amount_per_unit as cost_6mo_shipping_goal,
    fdp.units_needed_12mo_goal * prd.unit_price as cost_12mo_units_goal,
    fdp.units_needed_12mo_goal * fdp.avg_shipping_amount_per_unit as cost_12mo_shipping_goal,
    -- context metrics
    rsv.* except(product_sku)
from 
    ${ref('dim_product')} prd 
    left join future_demand_projection fdp on fdp.product_sku = prd.product_sku
    left join recent_sales_velocity rsv on rsv.product_sku = prd.product_sku
where 
    prd.product_status = 'Active'

